API_KEY=your_paynless_api_key_here
RENTMAN_API_TOKEN=your_rentman_jwt_token_here
SUNMI_APP_ID=your_sunmi_app_id_here
SUNMI_APP_KEY=your_sunmi_app_key_here
# Auth — generate with: node tools/set-password.js <password>
AUTH_PASSWORD_HASH=
SESSION_SECRET=
# Printing — shared secret between the cloud server and the NUC print agent.
# Set the SAME value on both. Generate one with:  openssl rand -hex 32
PRINT_AGENT_TOKEN=
# Agent-only (set in the NUC's .env): base URL of the online service, e.g.
# CLOUD_URL=https://scannerman.example.com
